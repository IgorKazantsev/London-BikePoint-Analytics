  create  table "bikepoint"."public_gold"."gold_station_depletion_rate__dbt_tmp"
  
  
    as
  
  (
    with recent_history as (

    select *
    from public_silver.silver_bikepoint_status
    where snapshot_timestamp >= now() - interval '24 hours'

),

station_history as (

    select
        bikepoint_id,
        station_name,
        snapshot_timestamp,
        nb_bikes,

        first_value(nb_bikes) over (
            partition by bikepoint_id
            order by snapshot_timestamp
        ) as first_bikes,

        first_value(nb_bikes) over (
            partition by bikepoint_id
            order by snapshot_timestamp desc
        ) as last_bikes,

        min(snapshot_timestamp) over (
            partition by bikepoint_id
        ) as first_ts,

        max(snapshot_timestamp) over (
            partition by bikepoint_id
        ) as last_ts

    from recent_history

),

station_rates as (

    select distinct
        bikepoint_id,
        station_name,
        last_ts as snapshot_timestamp,
        first_bikes,
        last_bikes,

        extract(epoch from (last_ts - first_ts)) / 3600.0
            as hours_observed,

        (last_bikes - first_bikes)::numeric
            as bike_change

    from station_history

)

select
    bikepoint_id,
    station_name,
    snapshot_timestamp,
    first_bikes,
    last_bikes,
    round(hours_observed::numeric, 2) as hours_observed,
    round(bike_change, 2) as bike_change,

    abs(
        round(
            bike_change / nullif(hours_observed, 0),
            2
        )
    ) as bike_demand_per_hour

from station_rates
where hours_observed > 0
  and bike_change < 0
  );
  
[0m19:07:01.843690 [debug] [Thread-3 (]: On model.london_bikepoint.silver_bikepoint_status: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "london_bikepoint", "target_name": "dev", "node_id": "model.london_bikepoint.silver_bikepoint_status"} */

  
    

  create  table "bikepoint"."public_silver"."silver_bikepoint_status__dbt_tmp"
  
  
    as
  
  (
    with raw as (
    select
        id as raw_id,
        snapshot_timestamp,
        jsonb_array_elements(raw_json) as station
    from bronze.bikepoint_raw
),

parsed as (
    select
        raw_id,
        snapshot_timestamp,

        station ->> 'id' as bikepoint_id,
        station ->> 'commonName' as station_name,
        station ->> 'placeType' as place_type,
        (station ->> 'lat')::numeric as latitude,
        (station ->> 'lon')::numeric as longitude,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbbikes'
            limit 1
        )::integer as nb_bikes,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbdocks'
            limit 1
        )::integer as nb_docks,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbspaces'
            limit 1
        )::integer as nb_spaces,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbemptydocks'
            limit 1
        )::integer as nb_empty_docks,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbstandardbikes'
            limit 1
        )::integer as nb_standard_bikes,

        (
            select prop ->> 'value'
            from jsonb_array_elements(station -> 'additionalProperties') prop
            where lower(prop ->> 'key') = 'nbebikes'
            limit 1
        )::integer as nb_ebikes

    from raw
)

select *
from parsed
  );
  
[0m19:07:01.845701 [debug] [Thread-1 (]: On model.london_bikepoint.gold_hourly_station_demand: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "london_bikepoint", "target_name": "dev", "node_id": "model.london_bikepoint.gold_hourly_station_demand"} */

  
    

  create  table "bikepoint"."public_gold"."gold_hourly_station_demand__dbt_tmp"
  
  
    as
  
  (
    with hourly_history as (

    select
        date_trunc('hour', snapshot_timestamp) as hour_bucket,
        bikepoint_id,
        station_name,
        snapshot_timestamp,
        nb_bikes
    from public_silver.silver_bikepoint_status
    where snapshot_timestamp >= now() - interval '24 hours'

),

hourly_stats as (

    select
        hour_bucket,
        bikepoint_id,
        station_name,

        first_value(nb_bikes) over (
            partition by hour_bucket, bikepoint_id
            order by snapshot_timestamp
        ) as first_bikes,

        first_value(nb_bikes) over (
            partition by hour_bucket, bikepoint_id
            order by snapshot_timestamp desc
        ) as last_bikes,

        min(snapshot_timestamp) over (
            partition by hour_bucket, bikepoint_id
        ) as first_ts,

        max(snapshot_timestamp) over (
            partition by hour_bucket, bikepoint_id
        ) as last_ts

    from hourly_history

),

hourly_rates as (

    select distinct
        hour_bucket,
        bikepoint_id,
        station_name,
        first_bikes,
        last_bikes,

        extract(epoch from (last_ts - first_ts)) / 3600.0 as hours_observed,

        (last_bikes - first_bikes)::numeric as bike_change

    from hourly_stats

)

select
    hour_bucket as snapshot_timestamp,
    bikepoint_id,
    station_name,
    first_bikes,
    last_bikes,
    round(hours_observed::numeric, 2) as hours_observed,
    round(bike_change, 2) as bike_change,

    abs(
        round(
            bike_change / nullif(hours_observed, 0),
            2
        )
    ) as bike_demand_per_hour

from hourly_rates
where hours_observed > 0
  and bike_change < 0
  );
  
